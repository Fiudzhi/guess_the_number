def main():
    print('Приветики! Это игра "угадай число"', 'Условия игры:', '1) У тебя будет 5 попыток', '2) Диапазон чисел будет от 0 до 30', '3) Числа будут только целые', sep='\n')

    import random

    pc_numb = random.randint(0, 30); #даём компу какое-то рандомное число от 0 до 30
    count = 4

    print('Ну что, начнём? Твоя первая попытка, укажи, пожалуйста, число:')
    user_numb = int(input())

    while count > 0:
        print(f'У тебя ещё {count} попыток')

        if user_numb > pc_numb:
            print('Число должно быть поменьше')
            count -= 1
            user_numb = int(input())
        elif user_numb < pc_numb:
            print('Нууу...загаданное число побольше')
            count -= 1
            user_numb = int(input())
        elif user_numb == pc_numb:
            print('Урааа, ты выиграл(-а)!') #завершение цикла, вдруг человек с первой попытки угадал, лол
            return
            count -= 1

    if count < 1:
            print('К сожалению, ты проиграл(-а). Можешь попробовать сыграть ещё раз', f'(если тебе интересно, то компьютер загадал такое число: {pc_numb})', sep='\n')


if __name__ == "__main__":
    main()
